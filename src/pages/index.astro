---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getAllGalleries, getSiteConfig } from '@/lib/galleries';

const site = getSiteConfig();
const galleries = getAllGalleries();
---
<BaseLayout title="Home" currentSlug="home">
  <section class="home-hero">
    <h1>{site.title}</h1>
    {site.tagline && <p>{site.tagline}</p>}
  </section>

  <section class="home-galleries" aria-label="Galleries">
    {galleries.map((gallery) => (
      <a href={`/${gallery.slug}/`} class="home-gallery-card">
        {gallery.cover && (
          <img src={gallery.cover.src} alt={gallery.cover.alt} class="card-cover" loading="lazy" />
        )}
        <div class="card-overlay">
          <span class="card-label">{gallery.title}</span>
        </div>
      </a>
    ))}
  </section>
</BaseLayout>
