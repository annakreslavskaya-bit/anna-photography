---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getSiteConfig } from '@/lib/galleries';

const site = getSiteConfig();
---
<BaseLayout
  title="About"
  currentSlug="about"
  description="About Anna Kreslavskaya — Boston-based photographer and artist."
>
  <article class="info-page">
    <h1>Anna Kreslavskaya</h1>

    <img src="/anna-about.jpg" alt="Anna Kreslavskaya" class="about-photo" />

    <p>
      Anna Kreslavskaya is a Boston-based photographer and artist specializing in portraits
      of children and adults, candid photography, flowers, fine art photography, and event
      photography — including conferences, banquets, corporate events, proms, weddings, and
      performances.
    </p>

    <h2>Printed Publications</h2>
    <ul>
      <li>Harvard University Mathematics Department Annual Publication, 2022–2023</li>
      <li>Harvard University CMES Annual Reports, 2007–2010</li>
      <li>Fall/Winter Knot, 2011</li>
    </ul>

    <h2>Online Presence</h2>
    <ul>
      <li>Harvard University, Mathematics Department, 2010–2024</li>
      <li>Harvard University, CMES, 2008–2012</li>
      <li>TurnPark Art Space</li>
    </ul>

    <h2>Exhibitions</h2>
    <ul>
      <li><a href="https://www.lasell.edu/academics/academic-centers/yamawaki-art-and-cultural-center/wedeman-art-gallery.html" target="_blank" rel="noopener noreferrer">Wedeman Gallery, Lasell University</a>, Newton, MA — Group, November 2025</li>
      <li><a href="https://www.hopartscenter.org/" target="_blank" rel="noopener noreferrer">Hopkinton Center for the Arts</a>, Hopkinton, MA — Group, June 2025</li>
      <li><a href="https://brickbottom.org" target="_blank" rel="noopener noreferrer">Brickbottom Artists Association</a>, Somerville, MA — Group, April 2025</li>
      <li><a href="https://brickbottom.org" target="_blank" rel="noopener noreferrer">Brickbottom Artists Association</a>, Somerville, MA — Group, July 2024</li>
      <li><a href="https://staffartshow.harvard.edu/" target="_blank" rel="noopener noreferrer">Harvard University Staff Art Show</a>, Gutman Library — May 2024</li>
      <li>Yahad: Together, Somerville, MA — Group, January 2024</li>
      <li><a href="https://arboretum.harvard.edu/" target="_blank" rel="noopener noreferrer">The Arnold Arboretum of Harvard University</a>, 2009</li>
    </ul>

    <h2>Services</h2>
    <ul>
      <li>Photography services</li>
      <li>Fine art prints</li>
    </ul>

    <h2>Contact</h2>
    <p>
      {site.social.email && (
        <><a href={`mailto:${site.social.email}`}>{site.social.email}</a><br /></>
      )}
      {site.social.instagram && (
        <><a href={site.social.instagram} target="_blank" rel="noopener noreferrer">Instagram</a></>
      )}
    </p>
  </article>
</BaseLayout>
